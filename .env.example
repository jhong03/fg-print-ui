# Copy this file to ".env" and fill in real values.
# The app reads .env on startup.

# Which database adapter to use: mock | mssql | postgres
# - mock     : built-in sample data, no database needed (default, good for trying the UI)
# - mssql    : Microsoft SQL Server  (npm i mssql)
# - postgres : PostgreSQL            (npm i pg)
DB_CLIENT=mock

# Port the local web server listens on
PORT=3000

# Company name printed at the top of the label
COMPANY_NAME=YOLLINK INDUSTRIES SDN BHD

# Fallback unit of measure (the data source has no UOM column)
DEFAULT_UOM=PCS

# ---------------------------------------------------------------------------
# Label printing (via the existing MES template + local print-agent)
# ---------------------------------------------------------------------------
# MES base URL — used to fetch the label template design
MES_BASE_URL=http://ec2-43-217-35-209.ap-southeast-5.compute.amazonaws.com:8081
# Which MES template to print (11 = "P1 FG Sticker")
LABEL_TEMPLATE_ID=11
# Local print-agent on this terminal (exposes /print-label on :9000)
AGENT_URL=http://localhost:9000
# Printer type the agent should use: tsc | hprt
PRINTER_TYPE=tsc

# Barcode horizontal calibration for the PHYSICAL print only (not the preview).
# The preview centers the barcode using an estimated width; the printer draws the
# real bars, so it can land a little off-centre. Nudge it here:
#   positive = move the printed barcode RIGHT, negative = LEFT.
#   8 dots ≈ 1 mm (203 dpi). e.g. barcode ~2 mm too far left -> set 16.
BARCODE_NUDGE_DOTS=0

# Which label version to print (live — no restart needed):
#   qc    = as the MES designed it, with the QC CHOP box + wording
#   plain = same label with the QC CHOP box and its wording removed
LABEL_VARIANT=qc

# One calibration per version. The barcode centres under the QC CHOP box, so
# removing the box shifts it and a single shared nudge cannot suit both.
# Falls back to BARCODE_NUDGE_DOTS above if unset.
BARCODE_NUDGE_DOTS_QC=0
BARCODE_NUDGE_DOTS_PLAIN=0

# ---------------------------------------------------------------------------
# SQL Server connection (used when DB_CLIENT=mssql)
# ---------------------------------------------------------------------------
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=your_database
MSSQL_USER=your_user
MSSQL_PASSWORD=your_password
# true = encrypt connection (usually true for Azure, false for local dev)
MSSQL_ENCRYPT=false
# true = accept self-signed certs (local/dev only)
MSSQL_TRUST_SERVER_CERT=true

# ---------------------------------------------------------------------------
# PostgreSQL connection (used when DB_CLIENT=postgres)
# ---------------------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=your_database
PG_USER=your_user
PG_PASSWORD=your_password
PG_SSL=false
